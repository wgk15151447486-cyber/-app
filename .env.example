# RoomReady AI — Environment Variables
# Copy this file to .env.local and fill in the values.

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Next.js
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# AI Provider
# Set AI_PROVIDER to "openai" or "deepseek"
# AI_PROVIDER=openai
# AI_BASE_URL=https://api.openai.com/v1

# OpenAI (requires AI_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# AI_TEXT_MODEL=gpt-4o
# AI_VISION_MODEL=gpt-4o
# AI_IMAGE_MODEL=dall-e-3
# IMAGE_GENERATION_QUALITY=standard
# IMAGE_GENERATION_SIZE=1024x1024

# DeepSeek (requires AI_PROVIDER=deepseek)
# AI_BASE_URL=https://api.deepseek.com
# DEEPSEEK_API_KEY=sk-...
# AI_TEXT_MODEL=deepseek-v4-flash
# AI_VISION_MODEL=deepseek-v4-flash
# AI_IMAGE_MODEL=mock

# Stripe Payments
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SINGLE_PROJECT_PRICE_ID=price_...
# NEXT_PUBLIC_APP_URL=http://localhost:3000
